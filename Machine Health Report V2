machine_a_temperature = 50
machine_a_power = 15
machine_a_alarm_level = 3
machine_a_operator = "John"
machine_a_status = "RUN"

def check_temperature(machine_temperature):
    if machine_temperature <= 40:
        return "Normal"
    elif machine_temperature <= 45:
        return "Warning"
    elif machine_temperature <= 47:
        return "Maintenance"   
    elif machine_temperature <= 49:
        return "Stop machine"
    else:
        return "Emergency"

def check_alarm_level(alarm_level):
    if alarm_level == 0:
        return "Normal"
    elif alarm_level == 1:
        return "Warning"
    elif alarm_level == 2:
        return "Maintenance"
    elif alarm_level == 3:
        return "Stop machine"
    else:
        return "Emergency"
    
result_temperature = check_temperature(machine_a_temperature)
result_alarm = check_alarm_level(machine_a_alarm_level)

print("Machine Health Check")
print("---------------------") 
print("machine:","Bottle Filling")
print("Temperature :", machine_a_temperature, "°C")
print("Temperature Status:", result_temperature)
print("Power Consumption:", machine_a_power, "A")
print("Alarm Level:", result_alarm)
print("Operator:", machine_a_operator)
print("Status:", machine_a_status)